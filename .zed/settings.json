{
    "lsp": {
        "rust-analyzer": {
            "initialization_options": {
                "check": {
                    "command": "clippy",
                    "extraArgs": [
                        "--",
                        "-W",
                        "clippy::pedantic",
                        "-W",
                        "clippy::nursery",
                    ],
                },
            },
        },
    },
}
