+    /// Wait until the peer has closed or reset a TCP stream without consuming
+    /// application data. The future resolves immediately for an already-removed
+    /// stream and is cancelled when the Rust network task shuts down.
+    #[pyo3(name = "wait_peer_gone")]
+    fn wait_peer_gone<'py>(&self, py: Python<'py>) -> PyResult<Bound<'py, PyAny>> {
+        let (tx, rx) = oneshot::channel();
+        self.command_tx
+            .send(TransportCommand::WaitPeerGone(self.connection_id, tx))
+            .map_err(event_queue_unavailable)?;
+        pyo3_async_runtimes::tokio::future_into_py(py, async move {
+            rx.await.map_err(|_| PyOSError::new_err("network task stopped"))
+        })
+    }
+
     /// Check whether this stream is being closed.
